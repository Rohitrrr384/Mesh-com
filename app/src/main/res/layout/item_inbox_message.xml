<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:minHeight="80dp"
        android:paddingEnd="12dp">

        <View
            android:id="@+id/viewUnreadDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_unread_dot" />

        <View
            android:id="@+id/viewInboxStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_alignBottom="@+id/contentLayout"
            android:layout_alignTop="@+id/contentLayout"
            android:layout_marginStart="26dp"
            android:background="#1565C0" />

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/viewInboxStripe"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:paddingStart="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvInboxType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:background="@drawable/bg_badge_inbox"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="DIRECT"
                    android:textColor="#1565C0"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tvInboxSender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tvInboxType"
                    android:layout_toStartOf="@id/tvInboxTime"
                    android:layout_marginStart="8dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:singleLine="true"
                    android:text="Pixel-Node-88"
                    android:textColor="#212121"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvInboxTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-light"
                    android:text="2m ago"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvInboxMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Hey, checking if the mesh connection is stable in your area..."
                android:textColor="#616161"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>