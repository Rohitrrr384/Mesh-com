<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7F6"> <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="60dp"
    app:cardBackgroundColor="#10CA8F"
    app:cardElevation="8dp"
    app:cardCornerRadius="0dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="MeshComm"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.05"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"/>
</androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:text="📡 Starting mesh…"
            android:textColor="#0D47A1"
            android:fontFamily="sans-serif-light"
            android:textSize="13sp"/>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/etDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Destination Node ID"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:textSize="14sp"
                android:textColorHint="#9E9E9E"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Type message…"
                    android:background="@android:color/transparent"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:textSize="16sp"/>

                <Button
                    android:id="@+id/btnSend"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:backgroundTint="#10CA8F"
                    android:text="Send"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#10CA8F"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <Button
            android:id="@+id/btnInbox"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_inbox"
            android:text="Inbox"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnTest"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_tools"
            android:text="Test"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnBroadcast"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_broadcast"
            android:text="Broadcast"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnPeers"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:drawableTop="@drawable/ic_peers"
            android:text="Peers"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>