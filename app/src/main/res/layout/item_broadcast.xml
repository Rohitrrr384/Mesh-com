<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF">

        <View
            android:id="@+id/viewCategoryStripe"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="#D32F2F" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvBcCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:background="@drawable/bg_badge_light"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="SOS"
                    android:textColor="#D32F2F"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tvBcSender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tvBcCategory"
                    android:layout_marginStart="10dp"
                    android:layout_centerVertical="true"
                    android:text="NODE-ALPHA"
                    android:textColor="#424242"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvBcTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="12:45 PM"
                    android:textColor="#BDBDBD"
                    android:textSize="11sp" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvBcMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="High signal interference detected in sector 4. Switching to mesh protocol."
                android:textColor="#212121"
                android:lineSpacingExtra="3dp"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>