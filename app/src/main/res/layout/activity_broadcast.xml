<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:cardBackgroundColor="#B71C1C"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="📡  Mesh Broadcast"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvBroadcastStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFEBEE"
        android:padding="10dp"
        android:gravity="center"
        android:text="Ready to broadcast"
        android:textColor="#B71C1C"
        android:textSize="12sp"
        android:letterSpacing="0.03" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="RECEIVED BROADCASTS"
        android:textColor="#757575"
        android:textSize="11sp"
        android:fontFamily="sans-serif-black" />

    <ListView
        android:id="@+id/lvBroadcasts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:padding="12dp"
        android:clipToPadding="false" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ANNOUNCE TO ALL NODES"
                android:textColor="#B71C1C"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etSenderName"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:hint="Your Name / ID"
                android:background="@drawable/bg_broadcast_input"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category: "
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#B71C1C" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <EditText
                    android:id="@+id/etBroadcastMsg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Type broadcast message…"
                    android:background="@android:color/transparent"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:minHeight="48dp"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnSendBroadcast"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#B71C1C"
                    android:text="SEND"
                    android:textAllCaps="true"
                    app:cornerRadius="8dp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>