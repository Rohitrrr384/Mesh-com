<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E88E5"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="🔧  MeshComm Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="THIS DEVICE"
        android:textColor="#90CAF9"
        android:textSize="11sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="4dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="12dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvMyNodeId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🆔 Node ID: loading…"
                android:textColor="#64B5F6"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView android:id="@+id/tvMyIp" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🌐 IP: …" android:textColor="#BDBDBD" android:textSize="13sp" android:layout_marginBottom="6dp" />
            <TextView android:id="@+id/tvGps" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📍 GPS: …" android:textColor="#BDBDBD" android:textSize="13sp" android:layout_marginBottom="6dp" />
            <TextView android:id="@+id/tvWifiStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📶 Wi-Fi: …" android:textColor="#BDBDBD" android:textSize="13sp" android:layout_marginBottom="6dp" />
            <TextView android:id="@+id/tvBtStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔵 Bluetooth: …" android:textColor="#BDBDBD" android:textSize="13sp" android:layout_marginBottom="6dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333" android:layout_marginVertical="8dp"/>

            <TextView
                android:id="@+id/tvPendingCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗃 DTN Queue: 0 messages pending"
                android:textColor="#81C784"
                android:textStyle="italic"
                android:textSize="13sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DISCOVERED NEIGHBORS"
        android:textColor="#90CAF9"
        android:textSize="11sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="4dp"/>

    <ListView
        android:id="@+id/lvNeighbors"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/bg_terminal_window"
        android:divider="#2C2C2C"
        android:dividerHeight="1dp"
        android:padding="4dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TEST ACTIONS"
        android:textColor="#90CAF9"
        android:textSize="11sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="4dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="Refresh"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            android:backgroundTint="#1565C0" />

        <Button
            android:id="@+id/btnSimulateHello"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="Fake Node"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            android:backgroundTint="#6A1B9A" />

        <Button
            android:id="@+id/btnSendTestMsg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="Self-Test"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            android:backgroundTint="#2E7D32" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="Clear Log"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            android:backgroundTint="#37474F" />
    </GridLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIVE EVENT LOG"
        android:textColor="#90CAF9"
        android:textSize="11sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="4dp"/>

    <TextView
        android:id="@+id/tvLog"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#000000"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:text="> System initialized\n> Mesh network ready"
        android:textColor="#00FF41"
        android:textSize="12sp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
</ScrollView>